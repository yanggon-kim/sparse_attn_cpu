# DeepSeek-V4 indexer trace instrumentation for antirez/ds4
# Upstream: https://github.com/antirez/ds4  commit 80ebbc396aee40eedc1d829222f3362d10fa4c6c (MIT)
# Apply from the ds4 repo root:  git apply ds4_instrumentation.patch  (or: patch -p1 < ...)
# Adds env-gated (DS4_TRACE_*) JSONL logging of CSA indexer top-k KV selections; build: make cpu
# ---
diff --git a/ds4.c b/ds4.c
index 640511e..bfdc0dd 100644
--- a/ds4.c
+++ b/ds4.c
@@ -9091,6 +9091,124 @@ static void layer_attention_prefix_batch(
 
 /* Ratio-4 layers use an auxiliary indexer to select which compressed rows are
  * visible to attention.  This is the CPU allocation-owning helper. */
+/* ---- DS4 indexer (sparse attention) selection logging ----
+ * Research instrumentation: when env var DS4_INDEXER_LOG is set to a file path,
+ * every indexer top-k selection is appended as one JSONL record:
+ *   {"layer":L,"pos":P,"n_comp":N,"top_k":K,"all":0/1,"sel":[...],"scores":[...]}
+ * "sel" lists the compressed-KV indices the sparse attention selected for the
+ * query at position P in layer L. "all":1 means n_comp<=top_k so everything was
+ * kept (no real sparsity yet). Gated + buffered; zero cost when env unset. */
+static FILE *g_indexer_log = NULL;
+static int g_indexer_log_init = 0;
+static pthread_mutex_t g_indexer_log_mutex = PTHREAD_MUTEX_INITIALIZER;
+static int g_trace_level = 1;              /* DS4_TRACE_LEVEL: 0 meta,1 selected,2 boundary,3 full */
+static uint32_t g_trace_flush_interval = 64;
+static uint64_t g_trace_record_count = 0;
+static double g_trace_full_rate = 0.0;     /* DS4_TRACE_FULL_SCORE_SAMPLE_RATE */
+static uint64_t g_trace_full_stride = 0;
+static int g_trace_decode_only = 0;        /* DS4_TRACE_DECODE_ONLY: skip prefill (phase 0) */
+static char g_trace_dir[1024] = {0};
+#define DS4_TRACE_SCHEMA_VERSION 2u
+
+static void indexer_log_close(void) {
+    if (g_indexer_log) { fflush(g_indexer_log); fclose(g_indexer_log); g_indexer_log = NULL; }
+}
+
+/* Resolve trace config + output once. Output precedence:
+ *   DS4_TRACE_OUTPUT (dir -> <dir>/indexer_trace.jsonl) > DS4_INDEXER_LOG (file, legacy)
+ *   > DS4_TRACE_ENABLE (-> ./ds4_indexer_trace.jsonl). */
+static void indexer_log_init_locked(void) {
+    g_indexer_log_init = 1;
+    const char *lvl = getenv("DS4_TRACE_LEVEL");
+    if (lvl && lvl[0]) g_trace_level = atoi(lvl);
+    const char *fi = getenv("DS4_TRACE_FLUSH_INTERVAL");
+    if (fi && fi[0]) { int v = atoi(fi); if (v > 0) g_trace_flush_interval = (uint32_t)v; }
+    const char *fr = getenv("DS4_TRACE_FULL_SCORE_SAMPLE_RATE");
+    if (fr && fr[0]) { g_trace_full_rate = atof(fr);
+        if (g_trace_full_rate > 0.0) g_trace_full_stride = (uint64_t)(1.0 / g_trace_full_rate + 0.5); }
+    const char *dco = getenv("DS4_TRACE_DECODE_ONLY");
+    if (dco && dco[0] && atoi(dco) != 0) g_trace_decode_only = 1;
+    char path[1280]; path[0] = 0;
+    const char *outdir = getenv("DS4_TRACE_OUTPUT");
+    const char *legacy = getenv("DS4_INDEXER_LOG");
+    const char *en = getenv("DS4_TRACE_ENABLE");
+    if (outdir && outdir[0]) {
+        snprintf(g_trace_dir, sizeof(g_trace_dir), "%s", outdir);
+        snprintf(path, sizeof(path), "%s/indexer_trace.jsonl", outdir);
+    } else if (legacy && legacy[0]) {
+        snprintf(path, sizeof(path), "%s", legacy);
+    } else if (en && en[0] && atoi(en) != 0) {
+        snprintf(path, sizeof(path), "ds4_indexer_trace.jsonl");
+    }
+    if (path[0]) {
+        g_indexer_log = fopen(path, "w");
+        if (!g_indexer_log) fprintf(stderr, "DS4 trace: cannot open %s\n", path);
+        else atexit(indexer_log_close);
+    }
+}
+
+/* One JSONL record per indexer top-k selection. phase: 0=prefill, 1=decode.
+ * Backend-neutral logical trace (schema_version DS4_TRACE_SCHEMA_VERSION). */
+static void indexer_log_selection(uint32_t il, uint32_t pos, uint32_t n_comp,
+                                  uint32_t top_k, const bool *allowed,
+                                  const float *scores, int all_selected, int phase) {
+    pthread_mutex_lock(&g_indexer_log_mutex);
+    if (!g_indexer_log_init) indexer_log_init_locked();
+    FILE *f = g_indexer_log;
+    if (!f || (g_trace_decode_only && phase == 0)) { pthread_mutex_unlock(&g_indexer_log_mutex); return; }
+
+    uint32_t valid_k = 0;
+    for (uint32_t c = 0; c < n_comp; c++) if (allowed[c]) valid_k++;
+
+    /* Level-2 boundary diagnostics: lowest selected score vs highest dropped score. */
+    int have_boundary = 0;
+    float rank_k_score = 0.0f, rank_kp1_score = 0.0f;
+    if (scores) {
+        int seen_sel = 0, seen_ns = 0;
+        for (uint32_t c = 0; c < n_comp; c++) {
+            if (allowed[c]) { if (!seen_sel || scores[c] < rank_k_score) { rank_k_score = scores[c]; seen_sel = 1; } }
+            else           { if (!seen_ns  || scores[c] > rank_kp1_score) { rank_kp1_score = scores[c]; seen_ns = 1; } }
+        }
+        have_boundary = seen_sel;
+        if (!seen_ns) rank_kp1_score = rank_k_score; /* nothing dropped */
+    }
+
+    const uint32_t ratio = ds4_layer_compress_ratio(il);
+    fprintf(f, "{\"sv\":%u,\"phase\":%d,\"layer\":%u,\"ratio\":%u,\"pos\":%u,"
+               "\"n_comp\":%u,\"top_k\":%u,\"valid_k\":%u,\"all\":%d",
+            (unsigned)DS4_TRACE_SCHEMA_VERSION, phase, il, ratio, pos,
+            n_comp, top_k, valid_k, all_selected);
+    if (have_boundary)
+        fprintf(f, ",\"rank_k_score\":%.6g,\"rank_kp1_score\":%.6g", rank_k_score, rank_kp1_score);
+    if (g_trace_level >= 1) {
+        int first = 1;
+        fprintf(f, ",\"sel\":[");
+        for (uint32_t c = 0; c < n_comp; c++)
+            if (allowed[c]) { fprintf(f, "%s%u", first ? "" : ",", c); first = 0; }
+        fprintf(f, "]");
+        if (scores) {
+            first = 1;
+            fprintf(f, ",\"scores\":[");
+            for (uint32_t c = 0; c < n_comp; c++)
+                if (allowed[c]) { fprintf(f, "%s%.6g", first ? "" : ",", scores[c]); first = 0; }
+            fprintf(f, "]");
+        }
+    }
+    /* Level-3: dump full candidate score vector to a binary sidecar for a sampled subset. */
+    if (g_trace_level >= 3 && scores && g_trace_full_stride > 0 && g_trace_dir[0] &&
+        (g_trace_record_count % g_trace_full_stride) == 0) {
+        char fp[1400];
+        snprintf(fp, sizeof(fp), "%s/full_scores/L%u_P%u.f32", g_trace_dir, il, pos);
+        FILE *bf = fopen(fp, "wb");
+        if (bf) { fwrite(scores, sizeof(float), n_comp, bf); fclose(bf);
+                  fprintf(f, ",\"full_scores\":\"full_scores/L%u_P%u.f32\"", il, pos); }
+    }
+    fprintf(f, "}\n");
+    g_trace_record_count++;
+    if ((g_trace_record_count % g_trace_flush_interval) == 0) fflush(f);
+    pthread_mutex_unlock(&g_indexer_log_mutex);
+}
+
 static bool *indexer_allowed_decode_one(
         const ds4_model         * model,
         const ds4_layer_weights * layer,
@@ -9106,6 +9224,7 @@ static bool *indexer_allowed_decode_one(
     const uint32_t top_k = DS4_N_INDEXER_TOP_K < n_comp ? DS4_N_INDEXER_TOP_K : n_comp;
     if (top_k == n_comp) {
         for (uint32_t i = 0; i < n_comp; i++) allowed[i] = true;
+        indexer_log_selection(il, pos, n_comp, top_k, allowed, NULL, 1, 0);
         return allowed;
     }
 
@@ -9147,6 +9266,8 @@ static bool *indexer_allowed_decode_one(
         allowed[best] = true;
     }
 
+    indexer_log_selection(il, pos, n_comp, top_k, allowed, scores, 0, 0);
+
     free(scores);
     free(weights);
     free(q);
@@ -9172,6 +9293,7 @@ static bool *indexer_allowed_decode_one_decode_scratch(
     const uint32_t top_k = DS4_N_INDEXER_TOP_K < n_comp ? DS4_N_INDEXER_TOP_K : n_comp;
     if (top_k == n_comp) {
         for (uint32_t i = 0; i < n_comp; i++) allowed[i] = true;
+        indexer_log_selection(il, pos, n_comp, top_k, allowed, NULL, 1, 1);
         return allowed;
     }
 
@@ -9213,6 +9335,8 @@ static bool *indexer_allowed_decode_one_decode_scratch(
         allowed[best] = true;
     }
 
+    indexer_log_selection(il, pos, n_comp, top_k, allowed, scores, 0, 1);
+
     return allowed;
 }
 
