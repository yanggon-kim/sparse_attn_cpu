+/* --- MoE routed-expert selection trace (research instrumentation) -----------
+ * When DS4_MOE_TRACE=1, every routed-MoE top-k expert selection on the CPU
+ * decode path is appended as one JSONL record to <DS4_TRACE_OUTPUT>/moe_trace.jsonl:
+ *   {"sv":1,"phase":P,"layer":L,"pos":Pos,"token":T,"n_expert":256,"n_used":6,
+ *    "is_hash":0/1,"sel":[...6 expert ids...],"weights":[...6...]}
+ * "sel" lists which experts the router chose (of DS4_N_EXPERT) for the token at
+ * position Pos in layer L. is_hash=1 marks the deterministic hash-routed early
+ * layers. Reuses DS4_TRACE_OUTPUT / DS4_TRACE_DECODE_ONLY / DS4_TRACE_FLUSH_INTERVAL.
+ * Gated + buffered; only the decode path calls it (prefill passes phase<0). */
+#define DS4_MOE_SCHEMA_VERSION 1u
+static FILE *g_moe_log = NULL;
+static int g_moe_log_init = 0;
+static int g_moe_log_enabled = 0;
+static pthread_mutex_t g_moe_log_mutex = PTHREAD_MUTEX_INITIALIZER;
+static uint32_t g_moe_flush_interval = 64;
+static uint64_t g_moe_record_count = 0;
+static int g_moe_decode_only = 0;
+
+static void moe_log_close(void) {
+    if (g_moe_log) { fflush(g_moe_log); fclose(g_moe_log); g_moe_log = NULL; }
+}
+
+static void moe_log_init_locked(void) {
+    g_moe_log_init = 1;
+    const char *en = getenv("DS4_MOE_TRACE");
+    if (!(en && en[0] && atoi(en) != 0)) return;   /* opt-in only */
+    const char *fi = getenv("DS4_TRACE_FLUSH_INTERVAL");
+    if (fi && fi[0]) { int v = atoi(fi); if (v > 0) g_moe_flush_interval = (uint32_t)v; }
+    const char *dco = getenv("DS4_TRACE_DECODE_ONLY");
+    if (dco && dco[0] && atoi(dco) != 0) g_moe_decode_only = 1;
+    char path[1400]; path[0] = 0;
+    const char *outdir = getenv("DS4_TRACE_OUTPUT");
+    const char *legacy = getenv("DS4_MOE_LOG");     /* explicit file path override */
+    if (legacy && legacy[0]) {
+        snprintf(path, sizeof(path), "%s", legacy);
+    } else if (outdir && outdir[0]) {
+        snprintf(path, sizeof(path), "%s/moe_trace.jsonl", outdir);
+    } else {
+        snprintf(path, sizeof(path), "ds4_moe_trace.jsonl");
+    }
+    g_moe_log = fopen(path, "w");
+    if (!g_moe_log) { fprintf(stderr, "DS4 MoE trace: cannot open %s\n", path); return; }
+    atexit(moe_log_close);
+    g_moe_log_enabled = 1;
+}
+
+/* One JSONL record per routed-MoE expert selection. phase: 0=prefill, 1=decode. */
+static void moe_log_selection(uint32_t il, uint32_t pos, int token,
+                              const int *selected, const float *weights,
+                              int n_used, int is_hash, int phase) {
+    pthread_mutex_lock(&g_moe_log_mutex);
+    if (!g_moe_log_init) moe_log_init_locked();
+    FILE *f = g_moe_log;
+    if (!f || !g_moe_log_enabled || (g_moe_decode_only && phase == 0)) {
+        pthread_mutex_unlock(&g_moe_log_mutex);
+        return;
+    }
+    fprintf(f, "{\"sv\":%u,\"phase\":%d,\"layer\":%u,\"pos\":%u,\"token\":%d,"
+               "\"n_expert\":%u,\"n_used\":%d,\"is_hash\":%d",
+            (unsigned)DS4_MOE_SCHEMA_VERSION, phase, il, pos, token,
+            (unsigned)DS4_N_EXPERT, n_used, is_hash);
+    fprintf(f, ",\"sel\":[");
+    for (int i = 0; i < n_used; i++) fprintf(f, "%s%d", i ? "," : "", selected[i]);
+    fprintf(f, "]");
+    if (weights) {
+        fprintf(f, ",\"weights\":[");
+        for (int i = 0; i < n_used; i++) fprintf(f, "%s%.6g", i ? "," : "", weights[i]);
+        fprintf(f, "]");
+    }
+    fprintf(f, "}\n");
+    g_moe_record_count++;
+    if ((g_moe_record_count % g_moe_flush_interval) == 0) fflush(f);
+    pthread_mutex_unlock(&g_moe_log_mutex);
+}
